# Maintainer: CADR Fonts maintainers <noreply@example.invalid>

pkgbase=cadr-fonts-git
pkgname=('cadr-fonts-latin-git' 'cadr-fonts-symbols-git')
pkgver=r1.g0000000
pkgrel=1
pkgdesc='Unicode-encoded MIT CADR bitmap fonts'
arch=('any')
url='https://github.com/htayj/CADR-fonts'
# Project work and the recovered upstream font payload are both BSD-3-Clause;
# the package installs their distinct LICENSE.project and LICENSE.source files.
license=('BSD-3-Clause')
makedepends=('git' 'python' 'xorg-fonttosfnt')
options=('!strip')
source=(
  'CADR-fonts::git+https://github.com/htayj/CADR-fonts.git'
  'mit-cadr-system-software::git+https://github.com/mietek/mit-cadr-system-software.git'
)
sha256sums=('SKIP' 'SKIP')

pkgver() {
  cd CADR-fonts
  printf 'r%s.g%s\n' \
    "$(git rev-list --count HEAD)" \
    "$(git rev-parse --short=7 HEAD)"
}

prepare() {
  cd CADR-fonts

  # makepkg fetches both Git repositories as declared sources.  Redirect the
  # submodule to that local clone, then let the superproject select the exact
  # reviewed CADR revision recorded in its index.
  git config \
    submodule.sources/mit-cadr-system-software.url \
    "${srcdir}/mit-cadr-system-software"
  git -c protocol.file.allow=always submodule update --init
}

build() {
  cd CADR-fonts
  local epoch
  epoch=$(git show -s --format=%ct HEAD)
  make release \
    VERSION="${pkgver}" \
    SOURCE_DATE_EPOCH="${epoch}"
}

package_cadr-fonts-latin-git() {
  pkgdesc='Unicode-encoded MIT CADR fonts containing Latin letters (VCS)'
  depends=('fontconfig')
  provides=("cadr-fonts-latin=${pkgver}")
  conflicts=('cadr-fonts-latin')
  backup=('etc/fonts/conf.d/75-cadr-fonts-latin.conf')

  cd CADR-fonts
  scripts/stage-linux-package.sh \
    --format arch \
    --group latin \
    --destdir "${pkgdir}" \
    --version "${pkgver}"
}

package_cadr-fonts-symbols-git() {
  pkgdesc='Unicode-encoded MIT CADR symbol and drawing fonts (VCS)'
  depends=('fontconfig')
  provides=("cadr-fonts-symbols=${pkgver}")
  conflicts=('cadr-fonts-symbols')
  backup=('etc/fonts/conf.d/75-cadr-fonts-symbols.conf')

  cd CADR-fonts
  scripts/stage-linux-package.sh \
    --format arch \
    --group symbols \
    --destdir "${pkgdir}" \
    --version "${pkgver}"
}
