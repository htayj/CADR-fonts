# Local template for 'cadr-fonts-latin'; see packaging/void/README.md.
pkgname=cadr-fonts-latin
version=0.1.0
revision=1
archs="noarch"
hostmakedepends="python3"
depends="fontconfig xbps-triggers"
short_desc="Unicode-encoded MIT CADR fonts containing Latin letters"
maintainer="CADR Fonts maintainers <noreply@example.invalid>"
# Project work and the recovered upstream font payload are both BSD-3-Clause;
# the package installs their distinct LICENSE.project and LICENSE.source files.
license="BSD-3-Clause"
homepage="https://github.com/htayj/CADR-fonts"
font_dirs="/usr/share/fonts/cadr-fonts/latin/bdf/source /usr/share/fonts/cadr-fonts/latin/bdf/runtime /usr/share/fonts/cadr-fonts/latin/otb/source /usr/share/fonts/cadr-fonts/latin/otb/runtime"

# This remains a deliberately local template until v0.1.0 exists. Put the
# checkout and its built dist/release directory somewhere visible inside the
# xbps-src chroot, then set these variables in etc/conf.
do_install() {
	local src=${CADR_FONTS_SOURCE_DIR:-}
	local release_dir=${CADR_FONTS_RELEASE_DIR:-}
	if [ ! -x "${src}/scripts/stage-linux-package.sh" ]; then
		msg_error "set CADR_FONTS_SOURCE_DIR to a CADR-fonts checkout visible in the chroot\n"
	fi
	if [ ! -f "${release_dir}/CADR-fonts-latin-v${version}.tar.gz" ]; then
		msg_error "set CADR_FONTS_RELEASE_DIR to a checked v${version} release directory\n"
	fi
	"${src}/scripts/stage-linux-package.sh" \
		--format void \
		--group latin \
		--destdir "${DESTDIR}" \
		--version "v${version}" \
		--release-dir "${release_dir}"
}
